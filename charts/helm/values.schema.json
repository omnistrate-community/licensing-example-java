{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "default": "ghcr.io/omnistrate-community/licensing-example-java"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        },
        "tag": {
          "type": "string",
          "default": "latest"
        }
      },
      "required": ["repository"]
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "className": {
          "type": "string",
          "default": "nginx"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "host": {
          "type": "string",
          "default": "www.service.cloud"
        }, 
        "tls": {
          "type": "boolean",
          "default": false
        }, 
        "tlsSecret": {
          "type": "string",
          "default": "google-public-ca-tls"
        }
      },
      "required": ["enabled", "host"]
    },
    "subscriptionSecret": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      },
      "required": ["enabled"]
    },
    "instanceId": {
      "type": "string",
      "default": "default-instance-id"
    },
    "useTerraform": {
      "type": "boolean",
      "description": "Enable to require terraform-provisioned endpoint values (dbEndpoint1, dbEndpoint2, redisEndpoint, pubsubId)",
      "default": false
    },
    "endpoints": {
      "type": "object",
      "description": "Terraform-provisioned endpoints. Only enforced when useTerraform is true.",
      "properties": {
        "dbEndpoint1": {
          "type": "string",
          "description": "Database endpoint 1 from terraform output (db_endpoints_1)"
        },
        "dbEndpoint2": {
          "type": "string",
          "description": "Database endpoint 2 from terraform output (db_endpoints_2.endpoint)"
        },
        "redisEndpoint": {
          "type": "string",
          "description": "Redis endpoint from terraform output (redis_endpoint)"
        },
        "pubsubId": {
          "type": "string",
          "description": "Pub/Sub ID from terraform output (pubsub_id)"
        }
      }
    }
  },
  "required": ["replicaCount", "image", "ingress", "subscriptionSecret", "instanceId"]
}
